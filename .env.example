# ───────────────────────────────────────────────────────────────
# MODELO de variaveis de ambiente (SEM segredos — este arquivo VAI pro Git).
#
# Para usar de verdade:
#   1. Copie este arquivo para um novo chamado  .env.local
#   2. Preencha os valores com os dados do SEU projeto Supabase
#      (Supabase > Project Settings > API)
#   3. O .env.local NUNCA vai pro Git (esta protegido no .gitignore)
#
# Observacao: no Vite, toda variavel exposta ao frontend PRECISA
# comecar com o prefixo  VITE_  — caso contrario ela nao chega no app.
# ───────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
